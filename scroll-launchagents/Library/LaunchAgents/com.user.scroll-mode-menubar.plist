<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.scroll-mode-menubar</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>exec $HOME/.local/bin/ScrollModeMenubar.app/Contents/MacOS/ScrollModeMenubar</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/scroll-mode-menubar.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/scroll-mode-menubar.err.log</string>
</dict>
</plist>
